###
# Penyesuaian (Sesuai Toko) API Tests
# Base URL: http://localhost:3000/api/penyesuaian
# Note: This module only shows RECID='*' (unresolved) records
###

### Variables
@baseUrl = http://localhost:3000/api
@token = YOUR_JWT_TOKEN_HERE
@cabang = G033
@kdtk = TW75
@periode = 2511
@prdcd = 12345678

###############################################
# 1. AUTHENTICATION (Get Token First)
###############################################

### Login to get JWT token
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin2",
  "password": "admin123"
}

###############################################
# 2. SCREENING OPERATIONS (3 LEVELS)
###############################################

### LEVEL 1: Start screening for ALL cabang
GET {{baseUrl}}/penyesuaian/screening?cabang=All&periode={{periode}}
Authorization: Bearer {{token}}

###

### LEVEL 2: Start screening for specific cabang
GET {{baseUrl}}/penyesuaian/screening?cabang={{cabang}}&periode={{periode}}
Authorization: Bearer {{token}}

###

### LEVEL 3: Start screening for specific store (single store refresh)
# This is used when user clicks refresh button on a specific row in UI
GET {{baseUrl}}/penyesuaian/screening?kdtk={{kdtk}}&periode={{periode}}
Authorization: Bearer {{token}}

###

### Screening without periode (should fail - validation test)
GET {{baseUrl}}/penyesuaian/screening?cabang={{cabang}}
Authorization: Bearer {{token}}

###

### Screening with invalid periode format (should fail)
GET {{baseUrl}}/penyesuaian/screening?cabang={{cabang}}&periode=202511
Authorization: Bearer {{token}}

###

### LEVEL 3: Screening specific store with different kdtk
GET {{baseUrl}}/penyesuaian/screening?kdtk=T001&periode={{periode}}
Authorization: Bearer {{token}}

###############################################
# 3. SUMMARY & STATISTICS
###############################################

### Get summary for specific cabang and periode (RECID='*' only)
GET {{baseUrl}}/penyesuaian/summary?cabang={{cabang}}&periode={{periode}}
Authorization: Bearer {{token}}

###

### Get summary for all cabang (RECID='*' only)
GET {{baseUrl}}/penyesuaian/summary?cabang=All&periode={{periode}}
Authorization: Bearer {{token}}

###

### Get summary without periode (should fail)
GET {{baseUrl}}/penyesuaian/summary?cabang={{cabang}}
Authorization: Bearer {{token}}

###

### Get summary for previous periode (for comparison)
GET {{baseUrl}}/penyesuaian/summary?cabang={{cabang}}&periode=2510
Authorization: Bearer {{token}}

