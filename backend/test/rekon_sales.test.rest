# 11. WORKFLOW SIMULATION (Urutan Realistis)
###############################################

### WORKFLOW A: Screening Awal Bulan
#
# Step 1: Screening semua cabang (bisa lama)
GET {{baseUrl}}/rekon-sales/screening?cabang=All&periode={{periode}}
Authorization: Bearer {{token}}

### Step 2: Lihat summary hasil screening
GET {{baseUrl}}/rekon-sales/summary?cabang=All&month={{month}}&year={{year}}
Authorization: Bearer {{token}}

### Step 3: Lihat daftar toko bermasalah (sort selisih terbesar)
GET {{baseUrl}}/rekon-sales/resumePerShop?month={{month}}&year={{year}}&sortColumn=TOTAL_SEL_NET_GL&sortOrder=DESC&limit=50
Authorization: Bearer {{token}}

###

### WORKFLOW B: Investigasi 1 Toko Bermasalah
#
# Step 1: Lihat detail breakdown per hari
GET {{baseUrl}}/rekon-sales/details?kdtk={{kdtk}}&month={{month}}&year={{year}}
Authorization: Bearer {{token}}

### Step 2: Lihat detail dokumen yang berbeda (mtran vs closing_detail)
GET {{baseUrl}}/rekon-sales/differences?kdtk={{kdtk}}&month={{month}}&year={{year}}
Authorization: Bearer {{token}}

### Step 3: Lihat kode pesanan yang bermasalah
GET {{baseUrl}}/rekon-sales/kodePesananIssues?kdtk={{kdtk}}&month={{month}}&year={{year}}
Authorization: Bearer {{token}}

### Step 4: Tambah catatan penanganan
PUT {{baseUrl}}/rekon-sales/note
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "cabang": "{{cabang}}",
  "kdtk": "{{kdtk}}",
  "tanggal": "2025-05-15",
  "noteText": "Sudah koordinasi ke kepala toko, data akan diperbaiki besok"
}

###

### WORKFLOW C: Re-screening Setelah Toko Perbaiki Data
#
# Step 1: Re-screening toko spesifik (single store)
GET {{baseUrl}}/rekon-sales/screening?kdtk={{kdtk}}&periode={{periode}}
Authorization: Bearer {{token}}

### Step 2: Cek apakah masih ada issue (jika resolved, tidak muncul)
GET {{baseUrl}}/rekon-sales/details?kdtk={{kdtk}}&month={{month}}&year={{year}}
Authorization: Bearer {{token}}

### Step 3: Cek summary – apakah total issue berkurang
GET {{baseUrl}}/rekon-sales/summary?cabang=All&month={{month}}&year={{year}}
Authorization: Bearer {{token}}

###

### WORKFLOW D: Export Laporan Akhir Bulan
#
# Step 1: Get semua data resume untuk export
